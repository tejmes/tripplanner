@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery AntiForgery
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TripPlanner</title>
    <meta name="csrf-token" content="@AntiForgery.GetAndStoreTokens(ViewContext.HttpContext).RequestToken" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TripPlanner.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TripPlanner</a>
                @if (User.Identity.IsAuthenticated == true)
                {
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <button class="btn btn-secondary rounded-circle d-flex align-items-center justify-content-center p-0 profile-button" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person fs-5"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-area="User" asp-controller="Trip" asp-action="TripsOverview">Výlety</a></li>
                                <li><a class="dropdown-item" asp-area="Security" asp-controller="Account" asp-action="Settings">Nastavení</a></li>
                                <li>
                                    <form asp-area="Security" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">Odhlásit</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
                else
                {
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarCollapse">
                        <ul class="navbar-nav ms-auto text-center text-sm-start">
                            <li class="nav-item">
                                <a class="nav-link text-dark text-nowrap" asp-area="Security" asp-controller="Account" asp-action="Login">Přihlásit se</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark btn btn-primary ms-2" asp-area="Security" asp-controller="Account" asp-action="Register">Registrace</a>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>