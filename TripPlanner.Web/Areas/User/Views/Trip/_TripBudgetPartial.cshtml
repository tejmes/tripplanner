@model BudgetViewModel
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Statistika rozpočtu</h5>
        <p><strong>Celkové výdaje:</strong> @Model.Expenses.Sum(e => e.Amount).ToString("C")</p>
        <h6 class="mt-3">Výdaje podle uživatelů</h6>
        <ul class="list-group list-group-flush mb-3">
            @foreach (var kv in Model.UserTotals)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span><strong>@kv.Key</strong></span>
                    <span>@kv.Value.ToString("C")</span>
                </li>
            }
        </ul>
        @if (Model.Settlements.Any())
        {
            <h6>Vyrovnání mezi uživateli</h6>
            <ul class="list-group">
                @foreach (var s in Model.Settlements)
                {
                    <li class="list-group-item d-flex justify-content-between">
                        <span><strong>@s.From</strong> → <strong>@s.To</strong></span>
                        <span>@s.Amount.ToString("C")</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="alert alert-success mt-3">Všichni jsou vyrovnaní.</div>
        }
    </div>
</div>

<div class="d-flex my-4">
    <button class="btn btn-primary ms-auto" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
        <i class="bi bi-plus-lg"></i>Přidat výdaj
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped">
            <thead class="table-light">
                <tr>
                    <th>Datum</th>
                    <th>Hodnota</th>
                    <th>Popis</th>
                    <th>Zaplatil</th>
                    <th>Sdílí</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exp in Model.Expenses)
                {
                    <tr>
                        <td>@exp.Date.ToShortDateString()</td>
                        <td>@exp.Amount.ToString("C")</td>
                        <td>@exp.Description</td>
                        <td>@exp.PaidByUser</td>
                        <td>@string.Join(", ", exp.SharedWith)</td>
                        <td class="text-end">
                            <form asp-area="User" asp-controller="Budget" asp-action="DeleteExpense" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tripId" value="@Model.TripId" />
                                <input type="hidden" name="expenseId" value="@exp.ExpenseId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addExpenseModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-area="User" asp-controller="Budget" asp-action="AddExpense" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="tripId" value="@Model.TripId" />
            <div class="modal-header">
                <h5 class="modal-title" id="addExpenseModalLabel">Nový výdaj</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="expense-date" class="form-label">Datum</label>
                    <input id="expense-date" name="date" type="date" class="form-control" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="mb-3">
                    <label for="expense-amount" class="form-label">Hodnota</label>
                    <input id="expense-amount" name="amount" type="number" step="0.01" class="form-control" placeholder="Hodnota" required />
                </div>
                <div class="mb-3">
                    <label for="expense-description" class="form-label">Popis</label>
                    <input id="expense-description" name="description" type="text" class="form-control" placeholder="Popis" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Sdílet s</label>
                    <div class="checkbox-container border rounded p-2">
                        @foreach (var u in Model.Collaborators)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="sharedWithUserIds" value="@u.UserId" id="share-@u.UserId" />
                                <label class="form-check-label" for="share-@u.UserId">@u.UserName</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušit</button>
                <button type="submit" class="btn btn-primary">Uložit výdaj</button>
            </div>
        </form>
    </div>
</div>
