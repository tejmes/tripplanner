@model IEnumerable<ChecklistViewModel>
@{
    var tripId = (int)(ViewData["TripId"] ?? 0);
}
<div class="nav-tabs-wrapper mb-4">
    <ul class="nav nav-tabs">
        @for (int i = 0; i < Model.Count(); i++)
        {
            var list = Model.ElementAt(i);
            <li class="nav-item d-flex align-items-center me-2">
                <button class="nav-link @(i == 0 ? "active" : "") fw-semibold" id="tab-@list.ListId" data-bs-toggle="tab" data-bs-target="#pane-@list.ListId" type="button">
                    <i class="bi bi-list-check me-1"></i>@list.Title
                </button>
                <form asp-area="User" asp-controller="Checklist" asp-action="DeleteList" method="post" class="ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="listId" value="@list.ListId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Smazat seznam">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
            </li>
        }
        <li class="nav-item ms-auto">
            <form asp-area="User" asp-controller="Checklist" asp-action="CreateList" method="post" class="d-flex new-list-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tripId" value="@tripId" />
                <input name="title" class="form-control form-control-sm" placeholder="Nový seznam" required />
                <button class="btn btn-sm btn-success ms-2" title="Vytvořit nový seznam">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </form>
        </li>
    </ul>
</div>
<div class="tab-content">
    @for (int i = 0; i < Model.Count(); i++)
    {
        var list = Model.ElementAt(i);
        <div class="tab-pane fade @(i == 0 ? "show active" : "")" id="pane-@list.ListId">
            <div class="list-group mb-3 shadow-sm rounded border">
                @foreach (var item in list.Items)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3 @(item.IsChecked ? "list-group-item-light" : "")">
                        <div class="d-flex align-items-center">
                            <form asp-area="User" asp-controller="Checklist" asp-action="Toggle" method="post" class="me-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <input type="checkbox" name="isChecked" class="form-check-input" @(item.IsChecked ? "checked" : "") onchange="this.form.submit()" />
                            </form>
                            <span class="@(item.IsChecked ? "text-decoration-line-through text-muted small" : "fw-medium")">@item.Text</span>
                        </div>
                        <form asp-area="User" asp-controller="Checklist" asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Odstranit položku">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
            <form asp-area="User" asp-controller="Checklist" asp-action="AddItem" method="post" class="input-group input-group-sm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="listId" value="@list.ListId" />
                <input name="text" type="text" class="form-control" placeholder="Přidat novou položku" required />
                <button type="submit" class="btn btn-success"><i class="bi bi-plus"></i></button>
            </form>
        </div>
    }
</div>
